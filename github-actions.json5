{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "packageRules": [
        {
            "matchManagers": [
                "github-actions",
            ],
            "pinDigests": true,
            "matchPackageNames": [
                "!actions/**",
                "!coopnorge/**",
            ],
        },
    ],
}
