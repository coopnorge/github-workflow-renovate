{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "github>coopnorge/github-workflow-renovate",
    ],
    "customManagers": [
        {
            "customType": "regex",
            "managerFilePatterns": ["/^\\.github/workflows/renovate\\.yaml$/"],
            "matchStrings": [
                "RENOVATE_VERSION:\\s*(?<currentValue>[0-9.]+)"
            ],
            "datasourceTemplate": "github-releases",
            "depNameTemplate": "renovatebot/renovate",
            "versioningTemplate": "semver",
        },
        {
            "customType": "regex",
            "managerFilePatterns": ["/^images/terraform-modules\\.Dockerfile$/"],
            "matchStrings": [
                "GO_VERSION\s*=\s*(?<currentValue>[0-9.]+)"
            ],
            "datasourceTemplate": "golang-version",
            "depNameTemplate": "go",
            "versioningTemplate": "semver"
        },
    ],
}
