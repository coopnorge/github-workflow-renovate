{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
    ],
    "automerge": true,
    "automergeStrategy": "squash",
    "rebaseWhen": "conflicted",
    "customManagers": [
        {
            "customType": "regex",
            "managerFilePatterns": ["/^.github/workflows/renovate.yaml$/"],
            "matchStrings": [
                "renovate-version:\\s*(?<currentValue>[0-9.]+)$"
            ],
            "datasourceTemplate": "github-releases",
            "depNameTemplate": "renovatebot/renovate",
            "versioningTemplate": "semver",
        },
    ],
    packageRules: [
        {
            "matchPackageNames": ["renovate/renovate", "ghcr.io/renovatebot/renovate"],
            "allowedVersions": "<=43.83.2"
        },
    ]
}
