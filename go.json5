{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "packageRules": [
        {
            "description": "No update cooldown for internal coopnorge modules",
            "minimumReleaseAge": "0 days",
            "matchDatasources": [
                "go"
            ],
            "matchPackageNames": [
                "github.com/coopnorge/**"
            ]
        },
        {
            "groupName": "dd-trace-go packages",
            "groupSlug": "dd-trace-go",
            "matchDatasources": [
                "go"
            ],
            "matchPackageNames": [
                "github.com/DataDog/dd-trace-go/**"
            ]
        },
        {
            "groupName": "echo packages",
            "groupSlug": "echo",
            "matchDatasources": [
                "go"
            ],
            "matchPackageNames": [
                "github.com/labstack/echo/**",
                "github.com/labstack/echo-jwt/**"
            ]
        }
    ]
}
