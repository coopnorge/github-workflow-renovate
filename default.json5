{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        "github>coopnorge/github-workflow-renovate:go",
        "github>coopnorge/github-workflow-renovate:docker",
    ],
    "labels": [
        "dependencies",
        "renovate",
        "{{depName}}"
    ],
    "prHourlyLimit": 5,
    "automerge": true,
    "automergeStrategy": "squash",
    "minimumReleaseAge": "14 days",
    "rebaseWhen": "conflicted",
    "postUpdateOptions": [
        "gomodTidy",
        "gomodUpdateImportPaths",
    ],
    "lockFileMaintenance": {
        "enabled": false,
    },
    "osvVulnerabilityAlerts": true,
    "vulnerabilityAlerts": {
        "enabled": true,
    },
}
