{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        "github>coopnorge/github-workflow-renovate:go.json5#v0.10.2",
        "github>coopnorge/github-workflow-renovate:docker.json5#v0.10.2",
        "github>coopnorge/github-workflow-renovate:helm-values.json5#v0.10.2",
        "github>coopnorge/github-workflow-renovate:helm.json5#v0.10.2",
        "github>coopnorge/github-workflow-renovate:python.json5#v0.10.2",
        "github>coopnorge/github-workflow-renovate:terraform.json5#v0.10.2"
    ],
    "labels": [
        "dependencies",
        "renovate",
        "{{depName}}"
    ],
    "prHourlyLimit": 5,
    "prConcurrentLimit": 0,
    "automerge": true,
    "automergeStrategy": "squash",
    "minimumReleaseAge": "14 days",
    "rebaseWhen": "conflicted",
    "postUpdateOptions": [
        "gomodTidy",
        "gomodUpdateImportPaths"
    ],
    "lockFileMaintenance": {
        "enabled": false
    },
    "osvVulnerabilityAlerts": true,
    "vulnerabilityAlerts": {
        "enabled": true
    }
}
