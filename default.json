{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
    ],
    "labels": [
        "dependencies",
        "renovate",
        "{{depName}}"
    ],
    "automerge": true,
    "automergeStrategy": "squash",
    "rebaseWhen": "conflicted",
    "postUpdateOptions": [
        "gomodTidy",
        "gomodUpdateImportPaths",
    ],
    "lockFileMaintenance": {
        "enabled": true,
    },
    "packageRules": [
        {
            "description": "Disable minimum release age checks for internal dependencies",
            "matchPackageNames": [
                "ghcr.io/coopnorge/engineering-docker-images/**",
                "github.com/coopnorge/**",
                "spacelift.io/coopnorge/**",
            ],
            "matchManagers": [
                "docker",
                "gomod",
                "iac",
            ],
            "minimumReleaseAge": null,
        },
    ],
}
